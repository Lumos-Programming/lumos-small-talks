# --- Auth.js (NextAuth.js v5) ---
# Linux/macOS: `openssl rand -hex 32` または https://generate-secret.vercel.app/32 で生成
AUTH_SECRET="your-auth-secret-here"
AUTH_URL="http://localhost:3000"

# --- Discord Provider ---
# Discord Developer Portal (https://discord.com/developers/applications) で取得
AUTH_DISCORD_ID="your-discord-client-id"
AUTH_DISCORD_SECRET="your-discord-client-secret"

# 参加を必須とする Discord サーバー (Guild) の ID
DISCORD_GUILD_ID="1234567890"

# Discord Bot Token (Admin機能でEventを作成するために必要)
DISCORD_BOT_TOKEN="YOUR.DISCORD.TOKEN"

# Admin権限を持つDiscordロールのID
ADMIN_ROLE_ID="1234567890"

# --- LINE Provider ---
# LINE Developers Console (https://developers.line.biz/console/) で取得
LINE_CHANNEL_ACCESS_TOKEN="YOUR_LINE_CHANNEL_ACCESS_TOKEN"
# LINE Messaging APIでメッセージを送信する際のターゲットID（ユーザーID、グループID、またはルームID）
LINE_PUSH_TARGET_ID="YOUR_LINE_PUSH_TARGET_ID"

# --- Firebase Admin SDK ---
# Google Cloud Console または Firebase Console で取得
FIREBASE_PROJECT_ID="your-firebase-project-id"

# ローカル開発でサービスアカウントキーを使用する場合
# Cloud Run では不要: Application Default Credentials (ADC) を自動使用
# 両方の環境変数を設定した場合のみサービスアカウントキーを使用
# FIREBASE_CLIENT_EMAIL="firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com"
# 改行を含む秘密鍵: "-----BEGIN PRIVATE KEY-----\nMIIEvgIBADANBgkqhkiG9w0BAQEFAASCBKgwggSkAgEAAoIBAQ..."
# FIREBASE_PRIVATE_KEY="your-firebase-private-key"

# --- Firestore Emulator (Local Development) ---
# ローカル開発ではエミュレータを使用 (`just dev` で自動起動)
# 本番 Firestore に接続する場合はコメントアウト
FIRESTORE_EMULATOR_HOST="localhost:8080"
